ype":"EXPERIMENTAL","description":"* Donor bone marrow will be harvested on Day -2\n* Bone Marrow incubated with irradiated recipient cells and anti-B7.1 and anti-B7.2 for 36 hours.\n* Bone marrow will be infused intravenously\n* Cyclophosphamide will be administered IV once daily\n* Total Body Irradiation (TBI) will be delivered per institutional practice\n* Methylprednisolone will be administered IV as 4 doses separated by 12 hours,","interventionNames":["Drug: cyclophosphamide","Drug: cyclosporine","Drug: leucovorin calcium","Drug: methotrexate","Drug: methylprednisolone","Procedure: in vitro-treated bone marrow transplantation","Radiation: radiation therapy"]}],"interventions":[{"type":"DRUG","name":"cyclophosphamide","armGroupLabels":["in vitro-treated bone marrow transplantation"]},{"type":"DRUG","name":"cyclosporine","armGroupLabels":["in vitro-treated bone marrow transplantation"]},{"type":"DRUG","name":"leucovorin calcium","armGroupLabels":["in vitro-treated bone marrow transplantation"]},{"type":"DRUG","name":"methotrexate","armGroupLabels":["in vitro-treated bone marrow transplantation"]},{"type":"DRUG","name":"methylprednisolone","armGroupLabels":["in vitro-treated bone marrow transplantation"]},{"type":"PROCEDURE","name":"in vitro-treated bone marrow transplantation","armGroupLabels":["in vitro-treated bone marrow transplantation"]},{"type":"RADIATION","name":"radiation therapy","armGroupLabels":["in vitro-treated bone marrow transplantation"]}]},"outcomesModule":{"primaryOutcomes":[{"measure":"Incidence of primary graft failure","timeFrame":"up to 30 days post-transplant"}],"secondaryOutcomes":[{"measure":"Incidence of hyperacute GVHD","timeFrame":"up to 100 days post-transplant"},{"measure":"Incidence of Grade D acute GVHD","timeFrame":"up to 50 days post-transplant"},{"measure":"Incidence of adverse events","timeFrame":"up to 100 days post-transplant"}]},"eligibilityModule":{"eligibilityCriteria":"Inclusion Criteria:\n\n* Age ≤40 years.\n* Diagnoses-